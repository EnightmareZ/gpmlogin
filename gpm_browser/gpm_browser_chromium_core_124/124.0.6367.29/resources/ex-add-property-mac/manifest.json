{
    "name": "Fake macOS",
    "description": "",
    "version": "1.0",
    "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'",
    "permissions": [
      "<all_urls>",
      "activeTab",
      "tabs",
      "webRequest",
      "webRequestBlocking",
      "storage",
      "privacy"
    ],
    "background": {
        "scripts":["background.js"]
      },
    "content_scripts": [
      {
        "matches": ["<all_urls>", "*://*/*"],
        "all_frames": true,
        "js": ["content-script.js"],
        "run_at": "document_start"
      }
    ],
    "manifest_version": 2,
    "web_accessible_resources": ["*"],
    "key": ""
  }