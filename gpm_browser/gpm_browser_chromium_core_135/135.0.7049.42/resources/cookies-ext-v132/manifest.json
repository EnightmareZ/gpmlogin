{
  "name": "GPM Login 119",
  "version": "1.6.0.0",
  "description": "",
  "offline_enabled": true,
  "incognito": "split",
  "permissions": [
    "cookies",
    "tabs",
    "windows",
    "privacy",
    "notifications",
    "management",
    "webNavigation",
    "storage",
    "webRequest",
    "webRequestBlocking",
    "contextMenus",
    "processes",
    "<all_urls>",
    "contextMenus",

    "chrome://resources/",
    "chrome://webui-test/",
    "contentSettings",
    "metricsPrivate"
  ],
  "background": {
    "page": "background.html",
    "persistent": true
  },
  "manifest_version": 2,
  "key": ""
}
